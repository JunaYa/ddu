{
  "name": "ddu",
  "type": "module",
  "version": "0.1.9",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:desktop": "tauri dev",
    "build": "pnpm build:web",
    "build:web": "vue-tsc --noEmit && vite build",
    "build:desktop": "tauri build --bundles app",
    "build:dmg": "tauri build --bundles dmg",
    "test": "pnpm build:web && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "lint": "echo 'eslint'",
    "lint:fix": "eslint . --fix",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-positioner": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@vueuse/core": "^14.3.0",
    "fabric": "^6.9.1",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@unocss/eslint-config": "^66.7.0",
    "@unocss/preset-mini": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.0",
    "unocss": "^66.7.0",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.1"
  },
  "dmg": {
    "background": "./images/",
    "windowSize": {
      "width": 200,
      "height": 150
    },
    "windowPosition": {
      "x": 400,
      "y": 400
    },
    "appPosition": {
      "x": 180,
      "y": 220
    },
    "applicationFolderPosition": {
      "x": 480,
      "y": 220
    }
  }
}
